{
  "info": {
    "name": "API de Pets - CRUD + Adoção",
    "_postman_id": "b7b7b9bb-9f8a-4e7c-8d79-6c8e6a7f9b2a",
    "description": "Collection básica para testar login e rotas de pets. Defina as variáveis baseUrl e token.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "token", "value": "" },
    { "key": "petId", "value": "" }
  ],
  "item": [
    {
      "name": "Users - Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{baseUrl}}/users/register", "host": ["{{baseUrl}}"], "path": ["users", "register"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Fulano\",\n  \"email\": \"fulano@email.com\",\n  \"phone\": \"11999999999\",\n  \"password\": \"123456\",\n  \"confirmpassword\": \"123456\"\n}"
        }
      }
    },
    {
      "name": "Users - Login (salva token)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "try {",
              "  const jsonData = pm.response.json();",
              "  if (jsonData.token) pm.collectionVariables.set('token', jsonData.token);",
              "} catch (e) {}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{baseUrl}}/users/login", "host": ["{{baseUrl}}"], "path": ["users", "login"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"fulano@email.com\",\n  \"password\": \"123456\"\n}"
        }
      }
    },
    {
      "name": "Pets - Create (multipart)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "try {",
              "  const jsonData = pm.response.json();",
              "  if (jsonData.pet && jsonData.pet._id) pm.collectionVariables.set('petId', jsonData.pet._id);",
              "} catch (e) {}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": { "raw": "{{baseUrl}}/pets/create", "host": ["{{baseUrl}}"], "path": ["pets", "create"] },
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "name", "value": "Rex", "type": "text" },
            { "key": "age", "value": "2", "type": "text" },
            { "key": "weight", "value": "10", "type": "text" },
            { "key": "color", "value": "Caramelo", "type": "text" },
            { "key": "images", "type": "file", "src": [] }
          ]
        }
      }
    },
    {
      "name": "Pets - Get All",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/pets", "host": ["{{baseUrl}}"], "path": ["pets"] }
      }
    },
    {
      "name": "Pets - My Pets",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": { "raw": "{{baseUrl}}/pets/mypets", "host": ["{{baseUrl}}"], "path": ["pets", "mypets"] }
      }
    },
    {
      "name": "Pets - My Adoptions",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": { "raw": "{{baseUrl}}/pets/myadoptions", "host": ["{{baseUrl}}"], "path": ["pets", "myadoptions"] }
      }
    },
    {
      "name": "Pets - Get By Id",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/pets/{{petId}}", "host": ["{{baseUrl}}"], "path": ["pets", "{{petId}}"] }
      }
    },
    {
      "name": "Pets - Update (PATCH)",
      "request": {
        "method": "PATCH",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": { "raw": "{{baseUrl}}/pets/{{petId}}", "host": ["{{baseUrl}}"], "path": ["pets", "{{petId}}"] },
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "name", "value": "Rex Atualizado", "type": "text" }
          ]
        }
      }
    },
    {
      "name": "Pets - Schedule Adoption",
      "request": {
        "method": "PATCH",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": { "raw": "{{baseUrl}}/pets/schedule/{{petId}}", "host": ["{{baseUrl}}"], "path": ["pets", "schedule", "{{petId}}"] }
      }
    },
    {
      "name": "Pets - Conclude Adoption",
      "request": {
        "method": "PATCH",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": { "raw": "{{baseUrl}}/pets/conclude/{{petId}}", "host": ["{{baseUrl}}"], "path": ["pets", "conclude", "{{petId}}"] }
      }
    },
    {
      "name": "Pets - Delete",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": { "raw": "{{baseUrl}}/pets/{{petId}}", "host": ["{{baseUrl}}"], "path": ["pets", "{{petId}}"] }
      }
    }
  ]
}
